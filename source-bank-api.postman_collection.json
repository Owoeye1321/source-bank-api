        {
          "name": "Get Transactions — Filter CREDIT",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('All transactions are CREDIT', () => {",
                  "    res.data.transactions.forEach(tx => {",
                  "        pm.expect(tx.transactionType).to.equal('CREDIT');",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userAToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/transactions?transactionType=CREDIT",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"],
              "query": [
                { "key": "transactionType", "value": "CREDIT" }
              ]
            }
          }
