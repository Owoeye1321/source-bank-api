        {
          "name": "Register User A",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    pm.collectionVariables.set('userAToken', res.data.token);",
                  "}",
                  "",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response has token', () => pm.expect(res.data.token).to.be.a('string'));",
                  "pm.test('Response has accountNumber', () => pm.expect(res.data.accountNumber).to.have.lengthOf(10));",
                  "pm.test('Email is lowercase', () => pm.expect(res.data.email).to.equal('usera@example.com'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usera@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
