          "name": "Deposit 5000 (User A)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has reference', () => pm.expect(res.data.reference).to.be.a('string'));",
                  "pm.test('Amount is 5000.00', () => pm.expect(res.data.amount).to.equal('5000.00'));",
                  "pm.test('Balance updated', () => {",
                  "    const prev = parseFloat(res.data.previousBalance);",
                  "    const curr = parseFloat(res.data.currentBalance);",
                  "    pm.expect(curr - prev).to.equal(5000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
